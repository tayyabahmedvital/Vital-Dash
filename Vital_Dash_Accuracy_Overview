-- ============================================================
-- RELATIVE ERROR HEATMAP
-- Y axis: sample (outer) + run_code (inner) 
-- X axis: assay
-- Color: mean relative error % centered at 0
-- ============================================================

WITH sample_details AS (
    SELECT 
        m.run_id, m.run_code, m.study_code,
        m.instrument_id,
        smpl.id AS sample_id,
        grp.code AS sample_group_code,
        COALESCE(grp.name, CONCAT('Run Lot: ', m.run_code)) AS sample_group_name
    FROM (
        SELECT tr.*, rcfg.sample_id 
        FROM (
            SELECT 
                r.id AS run_id, 
                r.code AS run_code,
                r.instrument_id,
                s.code AS study_code
            FROM experiment_run r
            INNER JOIN experiment_study s ON r.study_id = s.id
            WHERE s.code = '{{study_code}}'
        ) tr 
        LEFT JOIN experiment_runconfig rcfg ON tr.run_id = rcfg.run_id
    ) m 
    LEFT JOIN experiment_sample smpl ON m.sample_id = smpl.id
    LEFT JOIN experiment_samplegroup grp ON smpl.sample_group_id = grp.id
),
raw_assay_metrics AS (
    SELECT 
        sd.study_code,
        sd.run_id,
        sd.run_code,
        sd.sample_group_name,
        sd.instrument_id,
        inst.name                                                      AS instrument_name,
        sub.code AS structure_name,
        ind.code AS assay_name,
        res.calculated_value AS measured_value,
        res.actual_value AS reference_value,
        res.created_at AS date_of_measurement
    FROM sample_details sd
    INNER JOIN experiment_runresult res ON sd.run_id = res.run_id
    INNER JOIN experiment_indice ind ON res.indice_id = ind.id
    INNER JOIN instrumentation_subsystem sub ON res.subsystem_id = sub.id
    LEFT  JOIN instrumentation_instrument inst ON inst.id = sd.instrument_id
),
cleaned_measurements AS (
    SELECT
        study_code,
        run_id,
        run_code,
        sample_group_name,
        instrument_name,
        structure_name,
        assay_name,
        measured_value,
        reference_value,
        date_of_measurement,
        ROUND(((measured_value - reference_value) / NULLIF(reference_value, 0) * 100)::numeric, 4) AS relative_error_pct
    FROM raw_assay_metrics
    WHERE
        measured_value IS NOT NULL
        AND reference_value IS NOT NULL
        AND measured_value < 10000
        AND reference_value < 10000
        AND measured_value >= 0
),
summary AS (
    SELECT
        sample_group_name,
        run_code,
        instrument_name,
        structure_name,
        assay_name,
        CONCAT(structure_name, ': ', assay_name)                    AS structured_assay,
        CONCAT(sample_group_name, ' | ', run_code)                  AS sample_run_label,
        ROUND(AVG(relative_error_pct)::numeric, 2)                  AS mean_relative_error_pct,
        COUNT(*)                                                     AS n_measurements,
        MAX(DATE_TRUNC('day', date_of_measurement)::date)           AS latest_date
    FROM cleaned_measurements
    GROUP BY sample_group_name, run_code, instrument_name, structure_name, assay_name
),
assay_groups AS (
    SELECT
        assay_name,
        CASE
            WHEN assay_name IN ('NA', 'K', 'CL', 'CA', 'MG', 'PHOS')                        THEN 'Electrolytes'
            WHEN assay_name IN ('ALT', 'AST', 'ALP', 'ALB', 'TBIL', 'DBIL', 'TP', 'LDH')   THEN 'Liver Function'
            WHEN assay_name IN ('CREA', 'BUN', 'UA')                                          THEN 'Renal Function'
            WHEN assay_name IN ('GLU', 'CHOL', 'TRIG')                                        THEN 'Metabolic'
            ELSE 'Other'
        END AS assay_group
    FROM (SELECT DISTINCT assay_name FROM summary) t
),
base_rows AS (
    SELECT
        s.sample_run_label,
        s.structured_assay,
        s.mean_relative_error_pct,
        s.n_measurements,
        s.sample_group_name,
        s.run_code,
        s.instrument_name,
        s.latest_date,
        ag.assay_group
    FROM summary s
    LEFT JOIN assay_groups ag ON ag.assay_name = s.assay_name
)

-- Cross join generates all 16 combinations (2^4) for four independent filters:
--   Sample   (specific)
--   Run      (specific | All Runs)
--   Instrument (specific | All Instruments)
--   Assay Group (specific | All Groups)
-- Date filter uses latest_date per group — no "All" needed since it's per-row
-- Replace the final SELECT and CROSS JOIN with this:

SELECT
    b.sample_run_label                      AS sample_run,
    b.structured_assay                      AS assay,
    b.mean_relative_error_pct               AS relative_error,
    b.mean_relative_error_pct               AS color_value,
    b.n_measurements,
    b.sample_group_name                     AS "Sample::filter",
    CASE WHEN fg.use_all_run
        THEN 'All Runs'
        ELSE b.run_code
    END                                     AS "Run::filter",
    CASE WHEN fg.use_all_instrument
        THEN 'All Instruments'
        ELSE b.instrument_name
    END                                     AS "Instrument::filter",
    CASE WHEN fg.use_all_group
        THEN 'All Groups'
        ELSE b.assay_group
    END                                     AS "Assay Group::filter",
    CASE WHEN fg.use_all_date
        THEN 'All Dates'
        ELSE b.latest_date::text
    END                                     AS "Date::filter"
FROM base_rows b
CROSS JOIN (
    SELECT
        r.v AS use_all_run,
        i.v AS use_all_instrument,
        g.v AS use_all_group,
        d.v AS use_all_date
    FROM       (VALUES (false), (true)) r(v)
    CROSS JOIN (VALUES (false), (true)) i(v)
    CROSS JOIN (VALUES (false), (true)) g(v)
    CROSS JOIN (VALUES (false), (true)) d(v)
) fg

ORDER BY sample_run ASC, assay ASC;